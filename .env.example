# Supabase (KTP Blog project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The production deployment also has a tracked .env.production fallback with
# only these two NEXT_PUBLIC values. They are browser-public by design. Keep all
# private variables in Vercel/local .env only.

# Server-side chatbot
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Contact form fallback and analytics
RESEND_API_KEY=
NEXT_PUBLIC_GA_ID=

# Cloudinary upload scripts (server-side/local only)
CLOUDINARY_CLOUD_NAME=dha44tosd
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Legacy/portal integrations (only if those features are reactivated)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
